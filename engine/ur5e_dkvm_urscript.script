  # local result = scan_landmark(itm_id)
  # ==================================================

  send_command_status(msg_id, "COMPLETE", "result=Success")
end

def handle_process_at_3fg(msg, msg_id):
  local itm_id = to_num(dkvm_get_value(msg, "ITM_ID"))
  local jig_id = to_num(dkvm_get_value(msg, "JIG_ID"))
  local act = to_num(dkvm_get_value(msg, "ACT"))
  local obj_type = to_num(dkvm_get_value(msg, "OBJ_Type"))

  log_process(LS_INFO + "ProcessAt3FG: ITM=" + to_str(itm_id) + " JIG=" + to_str(jig_id) + " ACT=" + to_str(act) + " TYPE=" + to_str(obj_type))

  send_command_status(msg_id, "EXECUTING")

  # ===== INSERT 3FG PROCESSING LOGIC HERE =====
  # Example: capping / decapping / sample type detection
  # local barcode = process_3fg(itm_id, jig_id, act, obj_type)
  # ==================================================

  # For action 3 (DetermineSampleType), include barcode in response:
  if (act == 3):
    send_command_status(msg_id, "COMPLETE", "result=Success" + DKVM_FIELD_SEP + "barcode=SAMPLE001")
  else:
    send_command_status(msg_id, "COMPLETE", "result=Success")
  end
end

def handle_camera_inspect(msg, msg_id):
  local station = dkvm_get_value(msg, "STATION")
  local jig_id = to_num(dkvm_get_value(msg, "JIG_ID"))
  local camera = dkvm_get_value(msg, "CAMERA")

  log_process(LS_INFO + "CameraInspect: STATION=" + station + " JIG=" + to_str(jig_id) + " CAM=" + camera)

  send_command_status(msg_id, "EXECUTING")

  # ===== INSERT CAMERA INSPECT LOGIC HERE =====
  # Example: trigger wrist camera inspection
  # local positions = inspect_rack(station, jig_id)
  # ==================================================

  send_command_status(msg_id, "COMPLETE", "result=Success")
end

def handle_navigate(msg, msg_id):
  local pos_target = dkvm_get_value(msg, "AMR_PosTarget")
  local footprint = dkvm_get_value(msg, "AMR_Footprint")
  local dock = dkvm_get_value(msg, "AMR_DOCK")

  log_process(LS_INFO + "Navigate: target=" + pos_target + " footprint=" + footprint + " dock=" + dock)

  send_command_status(msg_id, "EXECUTING")

  # ===== INSERT AMR NAVIGATION LOGIC HERE =====
  # Example: send navigation command to AMR subsystem
  # navigate_amr(pos_target, footprint, dock)
  # ==================================================

  send_command_status(msg_id, "COMPLETE", "result=Success")
end


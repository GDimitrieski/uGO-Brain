def handle_update_world_state(msg, msg_id):
  log_process(LS_INFO + "UpdateWorldState_From_uLM: querying devices")

  send_command_status(msg_id, "EXECUTING")

  # ===== INSERT DEVICE STATE QUERY LOGIC HERE =====
  # local devices_str = query_all_device_states()
  # ==================================================
  local devices_str = "Devices: (5-COMPLETE; 7-COMPLETE)"

  send_command_status(msg_id, "COMPLETE", "result=Success" + DKVM_FIELD_SEP + "Devices=" + devices_str)
end

# Dispatch incoming CMD to the correct handler based on taskName.
def dispatch_command(msg, msg_id):
  local task_name = dkvm_get_value(msg, "taskName")

  if (task_name == "SingleTask"):
    handle_single_task(msg, msg_id)
  elif (task_name == "SingleDeviceAction"):
    handle_single_device_action(msg, msg_id)
  elif (task_name == "ProcessAt3FingerStation"):
    handle_process_at_3fg(msg, msg_id)
  elif (task_name == "CameraInspect"):
    handle_camera_inspect(msg, msg_id)
  elif (task_name == "Navigate"):
    handle_navigate(msg, msg_id)
  elif (task_name == "Charge"):
    handle_charge(msg, msg_id)
  elif (task_name == "UpdateWorldState_From_uLM"):
    handle_update_world_state(msg, msg_id)
  else:
    log_dev(LS_INFO + "Unknown taskName: " + task_name)
    send_command_status(msg_id, "ERROR", "error=UnknownTask")
  end
end


# ---- Background Threads (unchanged from original) --------------------------

thread WatchdogTimer():
  WatchdogTime = 0
  while (True):
    WatchdogTime = WatchdogTime + 1
    sleep(1)
  end
end

thread Reconnect():
  while (True):
    if (Socket_Connected == False):
      connectLS()
      if (get_plc_state() != uLMState.IDLE):
        set_plc_state(state = uLMState.IDLE)
      end
      log_process(LS_INFO + "Reconnected to LS")
    end
    sleep(0.25)
  end
end

thread WatchdogEvent():
  while (True):
    if (WatchdogTime >= 10):
      if (Socket_Connected == True):
        local alive = socket_alive(SOCKETNAME)
        if (alive == False):
          set_plc_state(state = uLMState.DISCONNECTED)
          sync()
          Socket_Connected = False
          sync()
        end
      end
      WatchdogTime = 0
    end
    sleep(0.5)
  end
end

# Heartbeat sender — responds to HB from planner and sends periodic HB.
thread HeartbeatResponder():
  while (True):
    if (Socket_Connected == True):
      local hb = dkvm_build_hb()
      dkvm_send(hb, SOCKETNAME)
    end
    sleep(3)
  end
end


# ---- Main Command Loop -----------------------------------------------------
# This is the primary loop that receives commands from the planner,
# dispatches them, and manages the uLM state machine.

def main_command_loop():
  # Start background threads
  run Reconnect()
  run WatchdogTimer()
  run WatchdogEvent()
  run HeartbeatResponder()

  set_plc_state(state = uLMState.DISCONNECTED)

  while (True):
    # Wait for connection
    if (Socket_Connected == False):
      sleep(0.25)
      continue
    end

    # Read next message
    local raw = dkvm_receive(SOCKETNAME, timeout_s = 2)
    if (str_len(raw) == 0):
      # Timeout — no message, loop back
      continue
    end

    # Parse message type
    local msg_type = dkvm_get_field(raw, 1)
    local msg_id = dkvm_get_field(raw, 2)

    if (msg_type == DKVM_HB):
      # Heartbeat from planner — reset watchdog
      WatchdogTime = 0
      continue
    end

    if (msg_type == DKVM_CMD):
      # Command received — ACK immediately, then execute
      send_command_ack(msg_id, SOCKETNAME)
      set_plc_state(state = uLMState.EXECUTING)

      dispatch_command(raw, msg_id)

      set_plc_state(state = uLMState.IDLE)
      continue
    end

    log_dev(LS_INFO + "Ignored message type: " + msg_type)
  end
end

# ---- Entry Point ------------------------------------------------------------
main_command_loop()

# =============================================================================
#  DKVM Protocol Library for UR5e (Polyscope 5.21+)
#  Delimited Key-Value Message protocol — matches engine/ur5e_protocol.py
#
#  Message format:  <VER>|<TYPE>|<ID>|key1=val1|key2=val2|...\n
#
#  This file is meant to be integrated into the UR5e Polyscope program.
#  It provides: receive_command(), send_ack(), send_status(), parse/build
#  helpers, and a main dispatch loop.
# =============================================================================

# ---- Configuration ----------------------------------------------------------
ORCHESTRATOR_IP = "192.168.13.120"
TESTPC_IP = "192.168.12.221"
ORCHESTRATOR_PORT = 30001
SOCKETNAME = "LS-Socket"
LS_INFO = "{LS ITF} "
ULMStateRegister = 1

uLMState = struct(UNKNOWN = 0, DISCONNECTED = 1, IDLE = 2, EXECUTING = 3, ERROR = 4)

global Socket_Connected = False
global WatchdogTime = 0
global Test = False

# DKVM protocol constants
DKVM_VERSION = 1
DKVM_FIELD_SEP = "|"
DKVM_KV_SEP = "="
DKVM_MSG_TERM = "\n"

# Message types
DKVM_CMD = "CMD"
DKVM_ACK = "ACK"
DKVM_STS = "STS"
DKVM_HB  = "HB"


# ---- PLC State Helpers (unchanged from original) ---------------------------

def get_plc_state():
  return read_output_integer_register(ULMStateRegister)
end

def set_plc_state(state):
  local current = read_output_integer_register(ULMStateRegister)
  if (current != state):
    write_output_integer_register(ULMStateRegister, state)
    if (state == uLMState.DISCONNECTED):
      log_dev(LS_INFO + "set ulm state to DISCONNECTED")
    elif (state == uLMState.IDLE):
      log_dev(LS_INFO + "set ulm state to IDLE")
    elif (state == uLMState.EXECUTING):
      log_dev(LS_INFO + "set ulm state to EXECUTING")
    elif (state == uLMState.ERROR):
      log_dev(LS_INFO + "set ulm state to ERROR")
    else:
      log_dev(LS_INFO + "set ulm state to UNKNOWN")
    end
  end
end


# ---- Connection Management (unchanged from original) -----------------------

def connectLS(ip = ORCHESTRATOR_IP, port = ORCHESTRATOR_PORT, socketname = SOCKETNAME):
  if (Test == True):
    ip = TESTPC_IP
  end
  if Socket_Connected == False and get_plc_state() != uLMState.DISCONNECTED:
    log_process(LS_INFO + "trying to connect to LS: " + to_str(ip) + ":" + to_str(port))
    set_plc_state(state = uLMState.DISCONNECTED)
  end
  while Socket_Connected == False:
    sleep(1)
    sync()
    Socket_Connected = socket_open(ip, port, socketname)
    sync()
  end
  if (get_plc_state() != uLMState.IDLE):
    set_plc_state(state = uLMState.IDLE)
  end
  log_process(LS_INFO + "control system connection established: " + to_str(ip) + ":" + to_str(port))
end

def socket_alive(socketname):
  local active = socket_send_string(" ", socket_name = socketname)
  if (active == False):
    socket_close(socketname)
    sync()
    Socket_Connected = active
    sync()
    log_process(LS_INFO + "heartbeat failed: " + to_str(socketname))
  end
  sync()
  return active
end


# ---- DKVM String Helpers ---------------------------------------------------
# URScript has no split() function, so we implement field extraction manually.

# Find the N-th field in a "|"-delimited string (0-indexed).
# Returns the field content, or "" if not found.
def dkvm_get_field(msg, index):
  local pos = 0
  local field_idx = 0
  local msg_len = str_len(msg)
  local start = 0

  while (pos <= msg_len):
    local ch = ""
    if (pos < msg_len):
      ch = str_sub(msg, pos, 1)
    end

    if (ch == DKVM_FIELD_SEP or pos == msg_len):
      if (field_idx == index):
        local length = pos - start
        if (length <= 0):
          return ""
        end
        return str_sub(msg, start, length)
      end
      field_idx = field_idx + 1
      start = pos + 1
    end
    pos = pos + 1
  end
  return ""
end

# Count the number of "|"-delimited fields in a message.
def dkvm_field_count(msg):
  local count = 1
  local pos = 0
  local msg_len = str_len(msg)
  while (pos < msg_len):
    if (str_sub(msg, pos, 1) == DKVM_FIELD_SEP):
      count = count + 1
    end
    pos = pos + 1
  end
  return count
end

# Extract the value for a given key from a "|"-delimited key=value message.
# Searches fields starting at index 3 (after VER|TYPE|ID).
# Returns "" if key not found.
def dkvm_get_value(msg, key):
  local num_fields = dkvm_field_count(msg)
  local i = 3
  while (i < num_fields):
    local fld = dkvm_get_field(msg, i)
    local eq_pos = str_find(fld, DKVM_KV_SEP)
    if (eq_pos >= 0):
      local k = str_sub(fld, 0, eq_pos)
      if (k == key):
        local v_start = eq_pos + 1
        local v_len = str_len(fld) - v_start
        if (v_len > 0):
          return str_sub(fld, v_start, v_len)
        else:
          return ""
        end
      end
    end
    i = i + 1
  end
  return ""
end


# ---- DKVM Message Builders -------------------------------------------------

# Build an ACK response:  1|ACK|<msg_id>|state=RECEIVED\n
def dkvm_build_ack(msg_id, state_val = "RECEIVED"):
  return to_str(DKVM_VERSION) + DKVM_FIELD_SEP + DKVM_ACK + DKVM_FIELD_SEP + msg_id + DKVM_FIELD_SEP + "state" + DKVM_KV_SEP + state_val + DKVM_MSG_TERM
end

# Build a STS response:  1|STS|<msg_id>|state=<state>|key=val|...\n
# extra_fields is a string of pre-formatted "|key=val" pairs (or "").
def dkvm_build_sts(msg_id, state_val, extra_fields = ""):
  local base = to_str(DKVM_VERSION) + DKVM_FIELD_SEP + DKVM_STS + DKVM_FIELD_SEP + msg_id + DKVM_FIELD_SEP + "state" + DKVM_KV_SEP + state_val
  if (str_len(extra_fields) > 0):
    base = base + DKVM_FIELD_SEP + extra_fields
  end
  return base + DKVM_MSG_TERM
end

# Build a HB response:  1|HB|0|ulm_state=<state>\n
def dkvm_build_hb():
  local st = get_plc_state()
  return to_str(DKVM_VERSION) + DKVM_FIELD_SEP + DKVM_HB + DKVM_FIELD_SEP + "0" + DKVM_FIELD_SEP + "ulm_state" + DKVM_KV_SEP + to_str(st) + DKVM_MSG_TERM
end


# ---- DKVM Send / Receive ---------------------------------------------------

def dkvm_send(msg_str, socketname = SOCKETNAME):
  local ok = socket_send_string(msg_str, socket_name = socketname)
  if (ok == False):
    log_dev(LS_INFO + "DKVM send failed")
    Socket_Connected = False
  end
  return ok
end

# Read one complete DKVM message (blocks until \n received or timeout).
# Returns the raw message string, or "" on timeout/error.
def dkvm_receive(socketname = SOCKETNAME, timeout_s = 2):
  local raw = socket_read_string(socketname, suffix = DKVM_MSG_TERM, timeout = timeout_s)
  if (str_len(raw) == 0):
    return ""
  end
  return raw
end

# Send ACK for a received command.
def send_command_ack(msg_id, socketname = SOCKETNAME):
  local ack = dkvm_build_ack(msg_id)
  dkvm_send(ack, socketname)
  log_dev(LS_INFO + "ACK sent for " + msg_id)
end

# Send status update for a task.
def send_command_status(msg_id, state_val, extra_fields = "", socketname = SOCKETNAME):
  local sts = dkvm_build_sts(msg_id, state_val, extra_fields)
  dkvm_send(sts, socketname)
  log_dev(LS_INFO + "STS " + state_val + " sent for " + msg_id)
end


# ---- Task Dispatch ----------------------------------------------------------
# This is where incoming CMD messages are routed to the appropriate handler.
# Each handler receives the raw message and msg_id, executes the task,
# and sends STS updates.

def handle_single_task(msg, msg_id):
  local itm_id = to_num(dkvm_get_value(msg, "ITM_ID"))
  local jig_id = to_num(dkvm_get_value(msg, "JIG_ID"))
  local obj_nbr = to_num(dkvm_get_value(msg, "OBJ_Nbr"))
  local act = to_num(dkvm_get_value(msg, "ACT"))
  local obj_type = to_num(dkvm_get_value(msg, "OBJ_Type"))

  log_process(LS_INFO + "SingleTask: ITM=" + to_str(itm_id) + " JIG=" + to_str(jig_id) + " OBJ=" + to_str(obj_nbr) + " ACT=" + to_str(act) + " TYPE=" + to_str(obj_type))

  send_command_status(msg_id, "EXECUTING")

  # ===== INSERT ACTUAL ROBOT MOTION LOGIC HERE =====
  # Example: call your existing SingleTask program/function
  # single_task_execute(itm_id, jig_id, obj_nbr, act, obj_type)
  # ==================================================

  send_command_status(msg_id, "COMPLETE", "result=Success")
end


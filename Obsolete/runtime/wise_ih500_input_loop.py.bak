import time
from pathlib import Path
from world.lab_world import ensure_world_config_file
from Device.registry import build_device_registry_from_world

DEVICE_ID = 'BIORAD_IH500_DEVICE_01'
INTERVAL_S = 1.0

world = ensure_world_config_file(Path('world/world_config.json'))
registry = build_device_registry_from_world(world)
module = registry.get_wise_module(DEVICE_ID)

print(f'Started Wise polling loop for {DEVICE_ID} (interval={INTERVAL_S}s)', flush=True)
while True:
    snap = module.poll_inputs(force=True)
    ch = snap.channels
    print(
        f"{snap.timestamp} online={snap.online} stale={snap.stale} "
        f"DI0={int(ch.get(0, False))} DI1={int(ch.get(1, False))} DI2={int(ch.get(2, False))} DI3={int(ch.get(3, False))} "
        f"err='{snap.error}'",
        flush=True,
    )
    time.sleep(INTERVAL_S)

